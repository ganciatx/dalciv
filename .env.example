# Production (Hostinger VPS / Docker)
# Caddy binds host 80/443; sivic is internal-only on 8765.
ACME_EMAIL=
SCRAPER_ENABLED=0
SOCRATA_APP_TOKEN=
# Trust X-Forwarded-* only from Docker bridge / reverse proxy (Caddy).
FORWARDED_ALLOW_IPS=127.0.0.1,172.16.0.0/12

# Background Socrata cache refresh (stale-while-revalidate)
DATA_SYNC_ENABLED=1
DATA_SYNC_TICK_SEC=15
POLICE_SYNC_INTERVAL_SEC=90
FINANCE_SYNC_INTERVAL_SEC=3600
VOTING_SYNC_INTERVAL_SEC=86400
BUDGET_SYNC_INTERVAL_SEC=86400

# Local development
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765
