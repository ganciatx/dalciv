					<div class="stl_01" style="left:15.4375em;top:48.9284em;"><a href="https://cityofdallas.legistar.com/gateway.aspx?M=F&amp;ID=0d48c3e0-f8d7-4881-a39d-13801223c92e.pdf" target="_blank"><span class="stl_47 stl_11">Memorandu<span class="stl_09">m &nbsp;</span></span></a></div>
