	<body>
		<div class="stl_02">
			<div class="stl_03">
				<img src="data:image/png;base64," alt="" class="stl_04" />
			</div>
			<div class="stl_view">
				<div class="stl_05 stl_06">
					<div class="stl_01" style="left:20.7417em;top:2.6246em;"><span class="stl_07" style="word-spacing:0em;">City of Dallas &nbsp;</span></div>
					<div class="stl_01" style="left:22.0042em;top:6.5948em;"><span class="stl_08 stl_09" style="word-spacing:0.07em;">1500 Marilla Street &nbsp;</span></div>
					<div class="stl_01" style="left:20.2208em;top:7.6573em;"><span class="stl_08 stl_09" style="word-spacing:0.06em;">Council Chambers, 6th Floor &nbsp;</span></div>
					<div class="stl_01" style="left:21.7083em;top:8.7198em;"><span class="stl_08 stl_09" style="word-spacing:0.06em;">Dallas, Texas 75201 &nbsp;</span></div>
					<div class="stl_01" style="left:15.9292em;top:21.7354em;"><span class="stl_10 stl_11" style="word-spacing:0em;">COUNCIL BRIEFING AGEND<span class="stl_09">A &nbsp;</span></span></div>
					<div class="stl_01" style="left:22.35em;top:26.5967em;"><span class="stl_12 stl_09" style="word-spacing:0.05em;">May 20, 2026 &nbsp;</span></div>
					<div class="stl_01" style="left:23.5125em;top:28.2842em;"><span class="stl_12 stl_09" style="word-spacing:0.06em;">9:00 AM &nbsp;</span></div>
					<div class="stl_01" style="left:12.6625em;top:52.1873em;"><span class="stl_13 stl_09" style="word-spacing:0.05em;">(For General Information and Rules of Courtesy, Please See Opposite Side.) &nbsp;</span></div>
					<div class="stl_01" style="left:13.5583em;top:53.1873em;"><span class="stl_13 stl_09" style="word-spacing:0.04em;">(La Información General Y Reglas De Cortesía Que Deben Observarse &nbsp;</span></div>
					<div class="stl_01" style="left:9.0875em;top:54.1873em;"><span class="stl_13 stl_09" style="word-spacing:0.04em;">Durante Las Asambleas Del Consejo Municipal Aparecen En El Lado Opuesto, Favor De Leerlas.) &nbsp;</span></div>
				</div>
			</div>
		</div>
		<div class="stl_14">
			<div class="stl_15">
				<img src="data:image/png;base64," alt="" class="stl_16" />
			</div>
			<div class="stl_view">
				<div class="stl_05 stl_17">
					<div class="stl_01" style="left:4.5625em;top:0.2149em;"><span class="stl_18 stl_09" style="word-spacing:0em;">General Infor<span class="stl_11">mation &nbsp;</span></span></div>
					<div class="stl_01" style="left:26em;top:0.2149em;"><span class="stl_18 stl_09" style="word-spacing:0.07em;">Información General &nbsp;</span></div>
					<div class="stl_01" style="left:4.5625em;top:2.1389em;"><span class="stl_19 stl_09" style="word-spacing:0.64em;">The Dallas City Council regularly meets on Wednesdays &nbsp;</span></div>
					<div class="stl_01" style="left:4.5625em;top:3.0764em;"><span class="stl_19 stl_09" style="word-spacing:0.91em;">beginning at 9:00</span><span class="stl_19" style="word-spacing:0em;">&nbsp;</span><span class="stl_19 stl_09" style="word-spacing:0.9em;">a.m. in the Council Chambers, 6th &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:2.1389em;"><span class="stl_19 stl_09" style="word-spacing:1.06em;">El Ayuntamiento de la Ciudad de Dallas se reúne &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:3.0764em;"><span class="stl_19 stl_20">regularm<span class="stl_21">ente &nbsp;</span></span></div>
					<div class="stl_01" style="left:31.4263em;top:3.0764em;"><span class="stl_19 stl_20">los &nbsp;</span></div>
					<div class="stl_01" style="left:33.5141em;top:3.0764em;"><span class="stl_19 stl_21">miércoles &nbsp;</span></div>
					<div class="stl_01" style="left:37.8132em;top:3.0764em;"><span class="stl_19 stl_21">en &nbsp;</span></div>
					<div class="stl_01" style="left:39.772em;top:3.0764em;"><span class="stl_19 stl_21">la &nbsp;</span></div>
					<div class="stl_01" style="left:41.5054em;top:3.0764em;"><span class="stl_19 stl_21">Cámara &nbsp;</span></div>
					<div class="stl_01" style="left:45.2301em;top:3.0764em;"><span class="stl_19 stl_21">del &nbsp;</span></div>
					<div class="stl_01" style="left:4.5625em;top:4.0139em;"><span class="stl_19 stl_09" style="word-spacing:0.72em;">floor, City Hall, 1500</span><span class="stl_19" style="word-spacing:0em;">&nbsp;</span><span class="stl_19 stl_11">Marill<span class="stl_09">a. &nbsp;</span></span></div>
					<div class="stl_01" style="left:4.5625em;top:4.9514em;"><span class="stl_19 stl_09" style="word-spacing:0.84em;">are broadcast live on </span><a href="https://www.dallascitynews.net/watch-live" target="_blank"><span class="stl_22 stl_11" style="word-spacing:0.8em;">bit.ly/cityofdal<span class="stl_09">lastv </span></span></a><span class="stl_19 stl_09" style="word-spacing:0.84em;">and on Time &nbsp;</span></div>
					<div class="stl_01" style="left:4.5625em;top:5.8889em;"><span class="stl_19 stl_09" style="word-spacing:0.7em;">Warner City Cable Channel 16.</span><span class="stl_19" style="word-spacing:1.59em;">&nbsp;</span><span class="stl_19 stl_09" style="word-spacing:0.73em;">Briefing meetings are &nbsp;</span></div>
					<div class="stl_01" style="left:15.6382em;top:4.0139em;"><span class="stl_19 stl_09" style="word-spacing:0.75em;">Council agenda meetings &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:4.0139em;"><span class="stl_19 stl_09" style="word-spacing:0.55em;">Ayuntamiento en el sexto piso de la Alcaldía, 1500</span><span class="stl_19" style="word-spacing:0em;">&nbsp;</span><span class="stl_19 stl_11">Marill<span class="stl_09">a, &nbsp;</span></span></div>
					<div class="stl_01" style="left:26em;top:4.9514em;"><span class="stl_19">a</span></div>
					<div class="stl_01" style="left:27.0503em;top:4.9514em;"><span class="stl_19 stl_09" style="word-spacing:0.75em;">las 9</span><span class="stl_19" style="word-spacing:0em;">&nbsp;</span><span class="stl_19 stl_09" style="word-spacing:0.76em;">de la mañana. &nbsp;</span></div>
					<div class="stl_01" style="left:35.7502em;top:4.9514em;"><span class="stl_19 stl_09" style="word-spacing:0.79em;">Las reuniones informativas se &nbsp;</span></div>
					<div class="stl_01" style="left:34.6056em;top:5.8889em;"><span class="stl_19 stl_09" style="word-spacing:0.53em;">y tercer miércoles del mes. Estas &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:5.8889em;"><span class="stl_19 stl_09" style="word-spacing:1.87em;">llevan cabo</span><span class="stl_19" style="word-spacing:0.48em;">&nbsp;</span><span class="stl_19 stl_09" style="word-spacing:0.54em;">el primer &nbsp;</span></div>
					<div class="stl_01" style="left:28.2754em;top:5.8889em;"><span class="stl_19">a</span></div>
					<div class="stl_01" style="left:4.5625em;top:6.8264em;"><span class="stl_19 stl_09" style="word-spacing:0.85em;">held the first and third Wednesdays of each month. &nbsp;</span></div>
					<div class="stl_01" style="left:4.5625em;top:7.7639em;"><span class="stl_19 stl_09" style="word-spacing:0.51em;">Council agenda (voting) meetings are held on the second &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:6.8264em;"><span class="stl_19 stl_09" style="word-spacing:0.48em;">audiencias se transmiten en vivo por la </span><a href="https://www.dallascitynews.net/watch-live" target="_blank"><span class="stl_22 stl_11" style="word-spacing:0.45em;">bit.ly/cityofdall<span class="stl_09">astv </span></span></a><span class="stl_19" style="word-spacing:0.45em;">y &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:7.7639em;"><span class="stl_19 stl_09" style="word-spacing:0.77em;">por cablevisión en la estación </span><span class="stl_23 stl_09" style="word-spacing:0.79em;">Time Warner City Cable &nbsp;</span></div>
					<div class="stl_01" style="left:4.5625em;top:8.7014em;"><span class="stl_19 stl_09" style="word-spacing:0.58em;">and fourth Wednesdays. &nbsp;</span></div>
					<div class="stl_01" style="left:13.6365em;top:8.7014em;"><span class="stl_19 stl_09" style="word-spacing:0.56em;">Anyone wishing to speak at &nbsp;</span></div>
					<div class="stl_01" style="left:23.7926em;top:8.7014em;"><span class="stl_19">a</span></div>
					<div class="stl_01" style="left:26em;top:8.7014em;"><span class="stl_19 stl_09" style="word-spacing:0.8em;">Canal 16. &nbsp;</span></div>
					<div class="stl_01" style="left:30.7633em;top:8.7014em;"><span class="stl_19 stl_09" style="word-spacing:0.79em;">El Ayuntamiento Municipal se reúne en el &nbsp;</span></div>
					<div class="stl_01" style="left:29.2184em;top:9.6389em;"><span class="stl_19 stl_09" style="word-spacing:0.7em;">y cuarto miércoles del mes para tratar asuntos &nbsp;</span></div>
					<div class="stl_01" style="left:4.5625em;top:9.6389em;"><span class="stl_19 stl_09" style="word-spacing:0.44em;">meeting should sign up with the City Secretary’s Office by &nbsp;</span></div>
					<div class="stl_01" style="left:4.5625em;top:10.5764em;"><span class="stl_19 stl_09" style="word-spacing:0.83em;">calling (214) 670-3738</span><span class="stl_19" style="word-spacing:0em;">&nbsp;</span><span class="stl_19 stl_09" style="word-spacing:0.8em;">by 5:00</span><span class="stl_19" style="word-spacing:0em;">&nbsp;</span><span class="stl_19 stl_09" style="word-spacing:0.8em;">p.m. of the last regular &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:9.6389em;"><span class="stl_19 stl_11">segun<span class="stl_09">do &nbsp;</span></span></div>
					<div class="stl_01" style="left:26em;top:10.5764em;"><span class="stl_19 stl_09" style="word-spacing:0.9em;">presentados de manera oficial en la agenda para su &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:11.5139em;"><span class="stl_19 stl_09" style="word-spacing:1.69em;">aprobación. Toda</span><span class="stl_19" style="word-spacing:0.66em;">&nbsp;</span><span class="stl_19 stl_09" style="word-spacing:0.7em;">persona que desee hablar durante la &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:12.4514em;"><span class="stl_19 stl_09" style="word-spacing:0.88em;">asamblea del Ayuntamiento, debe inscribirse llamando &nbsp;</span></div>
					<div class="stl_01" style="left:26em;top:13.3889em;"><span class="stl_19 stl_09" style="word-spacing:0.73em;">la Secretaría Municipal al teléfono (214) 670-3738, antes &nbsp;</span></div>
