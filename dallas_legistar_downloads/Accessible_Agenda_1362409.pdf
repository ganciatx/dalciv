					<div class="stl_01" style="left:15em;top:9.8228em;"><span class="stl_42">-</span></div>
					<div class="stl_01" style="left:16.5em;top:9.8228em;"><span class="stl_46 stl_09" style="word-spacing:0.71em;">(1) </span><span class="stl_42 stl_09" style="word-spacing:0.71em;">Deliberate the purchase, exchange, lease, or value of real &nbsp;</span></div>
